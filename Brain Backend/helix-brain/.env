# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HELIX-BRAIN — Environment (Local Dev)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# App
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Core API
CORE_API_BASE_URL=http://localhost:3000/v1
CORE_API_KEY=helix-internal-secret-dev-123
HELIX_BRAIN_INTERNAL_SECRET=helix-brain-dev-secret-456
CORE_API_TIMEOUT_MS=30000

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic — DUMMY (AI fallback mode enabled)
ANTHROPIC_API_KEY=sk-ant-dummy_replace_when_ready

# Feature flags — disable heavy jobs for local dev
ENABLE_AUTO_MODERATION=true
ENABLE_FRAUD_SWEEP=true
ENABLE_PAYOUT_PROCESSING=false
ENABLE_SELLER_EVALUATION=true
ENABLE_WEEKLY_REPORT=false
ENABLE_DISPUTE_MONITOR=true
ENABLE_RECOMMENDATION_REFRESH=false

# Rate limits
ADMIN_COMMAND_RATE_LIMIT=100
ADMIN_COMMAND_WINDOW_MS=3600000
