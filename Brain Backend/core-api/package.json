{
  "name": "core-api",
  "version": "1.0.0",
  "description": "HelixOnix Core API — The integration backbone connecting all 4 systems",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-s3": "^3.775.0",
    "@aws-sdk/s3-request-presigner": "^3.775.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "argon2": "^0.43.0",
    "bullmq": "^5.47.3",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.41.0",
    "fastify": "^5.3.2",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.14.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "replicate": "^1.4.0",
    "resend": "^4.1.2",
    "sharp": "^0.34.1",
    "socket.io": "^4.8.1",
    "stripe": "^17.7.0",
    "typesense": "^2.0.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
